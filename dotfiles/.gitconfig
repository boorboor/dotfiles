[user]
    name = Massoud Boorboor
    email = boorboor@gmail.com
    signingkey = 3236520BC1654D472D5D5E28068CFD621D4263B1
[push]
    default = current
    autoSetupRemote = true
[alias]
    s = status --short
    f = fetch --all --progress --tags
    l = log --pretty=oneline --graph --abbrev-commit -40
    d = diff
    b = branch -vv --sort committerdate
    co = checkout
    ll = log --pretty=format:'%h ┊ %G? ┊ %ar ┊ %aN ┊ %s'
    lf = log --pretty=format:'%h %an %s ' --name-status
    search = log -S
    conflict = diff --name-only --diff-filter=U
    unstage = reset HEAD --
[core]
    whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
    editor = nvim
    pager = less -F -X
    ignorecase = false
	excludesfile = /Users/dev/.config/git/global_ignores
[color]
    ui = true
[remote "origin"]
    prune = true
[merge]
    tool = vimdiff
    conflictStyle = zdiff3
    prompt = false
[pull]
    rebase = true
[credential]
    helper = osxkeychain
[diff]
    tool = vimdiff
    submodule = log
    colorMoved = zebra
[apply]
    whitespace = fix
[protocol]
    version = 2
[status]
    submodulesummary = 1
[fetch]
    prune = true
