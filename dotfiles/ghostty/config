theme = "TokyoNight Night"
background-opacity = 0.9
background-blur = 20
unfocused-split-opacity = 0.5

# --- Font (Crucial for your Neovim icons) ---
font-family = "JetBrains Mono Nerd Font"
font-size = 13

# --- Window & macOS UI ---
maximize = true
macos-titlebar-style = hidden
mouse-hide-while-typing = true
window-inherit-working-directory = true

# --- Terminal Behavior ---
shell-integration-features = sudo

# --- Split Management ---
keybind = super+enter=new_split:auto
keybind = super+z=toggle_split_zoom

# --- Navigation (Focus) ---
keybind = super+h=goto_split:left
keybind = super+j=goto_split:down
keybind = super+k=goto_split:up
keybind = super+l=goto_split:right

# --- Resizing Splits ---
keybind = super+ctrl+h=resize_split:left,10
keybind = super+ctrl+j=resize_split:down,10
keybind = super+ctrl+k=resize_split:up,10
keybind = super+ctrl+l=resize_split:right,10

# --- Tab Management ---
keybind = super+shift+enter=new_tab
keybind = super+left=previous_tab
keybind = super+right=next_tab
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5
keybind = super+6=goto_tab:6

# --- Window & App Actions ---
keybind = super+shift+z=toggle_fullscreen
